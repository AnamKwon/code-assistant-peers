{
  "name": "mcp-code-assistant-peers",
  "version": "0.2.0-alpha.0",
  "description": "MCP review gate that lets Claude Code, Codex, Gemini, and other CLI coding agents review each other",
  "type": "module",
  "license": "MIT",
  "author": "AnamKwon and contributors",
  "homepage": "https://github.com/AnamKwon/code-assistant-peers#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnamKwon/code-assistant-peers.git"
  },
  "bugs": {
    "url": "https://github.com/AnamKwon/code-assistant-peers/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "codex",
    "claude-code",
    "gemini",
    "ai-agents",
    "multi-agent",
    "code-review",
    "peer-review",
    "review-gate"
  ],
  "bin": {
    "code-assistant-peers": "./cli.ts",
    "code-assistant-peers-server": "./server.ts"
  },
  "engines": {
    "bun": ">=1.0"
  },
  "files": [
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "server.ts",
    "cli.ts",
    "shared",
    "scripts",
    "docs"
  ],
  "scripts": {
    "server": "bun server.ts",
    "cli": "bun cli.ts",
    "setup": "bun cli.ts setup both",
    "web-setup": "sh scripts/web-setup.sh",
    "test": "bun test",
    "typecheck": "bun ./node_modules/typescript/bin/tsc --noEmit",
    "check": "bun run typecheck && bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
